from neo4j import GraphDatabase
import logging

class Neo4jClient:
    """
    Abstraction layer for Neo4j interactions. 
    Implements Objective 1: Engineering Reliability.
    """
    def __init__(self, uri, user, password):
        self.driver = GraphDatabase.driver(uri, auth=(user, password))
        logging.info("Neo4j Driver initialized.")

    def close(self):
        self.driver.close()

    def execute_query(self, query, parameters=None):
        """
        Executes a query with built-in error handling for reliability.
        """
        with self.driver.session() as session:
            try:
                result = session.run(query, parameters)
                return [record.data() for record in result]
            except Exception as e:
                logging.error(f"Database Failure: {e}")
                return {"error": str(e)}
